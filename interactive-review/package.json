{
  "name": "interactive-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:quiz": "node scripts/build-quiz-data.mjs",
    "generate:reference": "node scripts/build-reference-index.mjs",
    "validate:source-map": "node scripts/validate-source-map.mjs",
    "generate:chapters": "node scripts/build-chapters-data.mjs",
    "generate": "npm run generate:reference && npm run generate:quiz && npm run validate:source-map && npm run generate:chapters",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run tests/answerCheck.test.ts tests/quizData.test.ts tests/theme.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/noto-serif-sc": "^5.2.8",
    "@vitejs/plugin-react": "^4.3.4",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
